/* pages/detail/detail.wxss —— 所有色值全部走 var() */

/* ── 档案编号横幅 ── */
.archive-banner {
  background-color: var(--bg-base);
  padding: 24rpx 32rpx;
}

.banner-grid-line {
  height: 1rpx;
  background: repeating-linear-gradient(
    90deg,
    var(--border) 0px, var(--border) 8px,
    transparent 8px, transparent 16px
  );
}

.banner-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.banner-no {
  display: block;
  font-size: 24rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
  margin-bottom: 6rpx;
}

.banner-label {
  display: block;
  font-size: 18rpx;
  color: var(--text-void);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

.banner-type-badge {
  padding: 8rpx 20rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  font-weight: 700;
}

.badge-type-folk     { background-color: var(--folk-bg);     color: var(--folk-text);     border: 1rpx solid var(--folk-border); }
.badge-type-official { background-color: var(--official-bg); color: var(--official-text); border: 1rpx solid var(--official-border); }
.badge-type-third    { background-color: var(--third-bg);    color: var(--third-text);    border: 1rpx solid var(--third-border); }

/* ── 标题区 ── */
.title-section {
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.title-main {
  font-size: 46rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.title-status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
}

.badge-status-ongoing {
  background-color: var(--accent-red-dim);
  color: var(--accent-red);
  border: 1rpx solid var(--accent-red-mid);
}

.badge-status-closed {
  background-color: var(--bg-elevated);
  color: var(--text-ghost);
  border: 1rpx solid var(--border);
}

.status-pulse { animation: pulse 1.5s ease-in-out infinite; }

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.3; }
}

.status-pulse-static { opacity: 0.6; }

.title-meta { display: flex; align-items: center; gap: 12rpx; }

.meta-lang {
  font-size: 22rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  border: 1rpx solid var(--border);
  padding: 2rpx 10rpx;
  border-radius: 3rpx;
}

.meta-dot   { color: var(--border); }
.meta-views { font-size: 22rpx; color: var(--text-phantom); font-family: var(--font-mono); }

/* ── 通用面板容器 ── */
.info-panel,
.content-panel,
.graph-panel,
.timeline-panel,
.evidence-panel,
.refs-panel {
  margin: 24rpx 24rpx 0;
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  background-color: var(--bg-card);
}

.panel-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  background-color: var(--bg-sunken);
  border-bottom: 1rpx solid var(--border);
}

.panel-header-code {
  font-size: 22rpx;
  color: var(--accent-red);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  font-weight: 700;
}

.panel-header-text {
  font-size: 26rpx;
  color: var(--text-muted);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

/* ── 基础信息面板 ── */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 18rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.info-row:last-child { border-bottom: none; }
.info-row--tags { align-items: flex-start; }

.info-key { font-size: 26rpx; color: var(--text-ghost);     font-family: var(--font-mono); flex-shrink: 0; margin-right: 24rpx; }
.info-val { font-size: 26rpx; color: var(--text-secondary); font-family: var(--font-mono); text-align: right; flex: 1; }
.info-val--unknown { color: var(--text-phantom); font-style: italic; }

/* 档案标签 */
.archive-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: flex-end;
  flex: 1;
}

.archive-tag {
  font-size: 20rpx;
  color: var(--text-muted);
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--border);
  padding: 4rpx 14rpx;
  border-radius: 32rpx;
  font-family: var(--font-mono);
}

/* ── 正文渲染（markdown 块级 + 图片 + 视频）── */
.content-body { padding: 28rpx 28rpx 8rpx; }

.video-seg {
  margin: 20rpx 0;
}

.seg-video {
  width: 100%;
  border-radius: 6rpx;
}

.seg-video-url {
  display: block;
  font-size: 20rpx;
  color: var(--text-void);
  font-family: var(--font-mono);
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.md-h1 {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  margin: 24rpx 0 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border);
}

.md-h2 {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin: 20rpx 0 14rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid var(--accent-red);
}

.md-h3 {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-secondary);
  line-height: 1.4;
  margin: 16rpx 0 12rpx;
}

.md-p {
  display: block;
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.9;
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
}

.md-bold   { font-weight: 700; color: var(--text-primary); }
.md-italic { font-style: italic; color: var(--text-secondary); }

.md-inline-code {
  font-family: var(--font-mono);
  font-size: 26rpx;
  color: var(--accent-green);
  background-color: var(--bg-elevated);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.md-blockquote {
  margin: 16rpx 0;
  padding: 16rpx 20rpx;
  background-color: var(--bg-elevated);
  border-left: 4rpx solid var(--accent-green);
  border-radius: 0 4rpx 4rpx 0;
  font-size: 28rpx;
  color: var(--text-ghost);
  line-height: 1.8;
}

.md-code-block {
  margin: 16rpx 0;
  background-color: var(--bg-sunken);
  border: 1rpx solid var(--border);
  border-radius: 6rpx;
  overflow: hidden;
}

.md-code-lang {
  display: block;
  font-size: 20rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  padding: 8rpx 20rpx;
  background-color: var(--bg-elevated);
  border-bottom: 1rpx solid var(--border);
  letter-spacing: 2rpx;
}

.md-code-text {
  display: block;
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  padding: 20rpx;
  white-space: pre-wrap;
}

.md-hr {
  height: 1rpx;
  background: repeating-linear-gradient(
    90deg,
    var(--border) 0px, var(--border) 8px,
    transparent 8px, transparent 16px
  );
  margin: 24rpx 0;
}

.md-image-block {
  margin: 16rpx 0;
  border-radius: 6rpx;
  overflow: hidden;
  border: 1rpx solid var(--border);
}

/* 骨架屏：图片加载期间占位 */
.md-img-skeleton {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(90deg, var(--bg-elevated) 25%, var(--bg-card) 50%, var(--bg-elevated) 75%);
  background-size: 200% 100%;
  animation: img-shimmer 1.4s ease-in-out infinite;
}

@keyframes img-shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 预加载触发器：不可见但在 DOM 中，供 lazy-load 监听 */
.md-img-preloader {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
  overflow: hidden;
}

.md-image {
  width: 100%;
  display: block;
}

.md-image-alt {
  display: block;
  font-size: 22rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  text-align: center;
  padding: 10rpx 16rpx;
  background-color: var(--bg-sunken);
}

.md-video-block {
  margin: 16rpx 0;
  border-radius: 6rpx;
  overflow: hidden;
  border: 1rpx solid var(--border);
}

.md-video {
  width: 100%;
  display: block;
}

.md-list { margin: 12rpx 0 20rpx; }

.md-list-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.md-list-bullet {
  color: var(--accent-green);
  font-size: 30rpx;
  flex-shrink: 0;
  line-height: 1.9;
}

.md-list-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.9;
  flex: 1;
}

/* ── Markdown 表格 ── */
.md-table-wrap {
  margin: 16rpx 0 24rpx;
  overflow: hidden;
  border-radius: 6rpx;
  border: 1rpx solid var(--border);
}

.md-table-scroll { width: 100%; }

.md-table {
  min-width: 100%;
  display: flex;
  flex-direction: column;
}

.md-table-head,
.md-table-row {
  display: flex;
  flex-direction: row;
}

.md-table-head {
  background-color: var(--bg-sunken);
  border-bottom: 1rpx solid var(--border);
}

.md-table-row--alt {
  background-color: var(--bg-elevated);
}

.md-th,
.md-td {
  flex: 1 0 200rpx;   /* 可增长、不缩小、基础宽 200rpx */
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  border-right: 1rpx solid var(--border-faint);
  box-sizing: border-box;
}

.md-th:last-child,
.md-td:last-child {
  border-right: none;
}

.md-th {
  font-family: var(--font-mono);
  font-weight: 700;
  color: var(--accent-green);
  letter-spacing: 1rpx;
}

.md-td {
  color: var(--text-secondary);
}

.md-table-row {
  border-bottom: 1rpx solid var(--border-faint);
}

.md-table-row:last-child {
  border-bottom: none;
}

.content-end-marker { padding: 8rpx 28rpx 24rpx; text-align: right; }

.end-marker-text {
  font-size: 20rpx;
  color: var(--text-void);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
}

/* ── 人物关系 ── */
.char-nodes { padding: 8rpx 0; }

.char-node {
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.char-node:last-child { border-bottom: none; }

.char-node-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.char-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--folk-border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.char-initial { font-size: 32rpx; color: var(--text-muted); font-family: var(--font-mono); }

.char-node-meta { flex: 1; }

.char-name { display: block; font-size: 30rpx; color: var(--text-primary); font-weight: 600; margin-bottom: 4rpx; }
.char-role { display: block; font-size: 22rpx; color: var(--accent-green); font-family: var(--font-mono); letter-spacing: 1rpx; }

.char-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 10rpx; }

.char-tag {
  font-size: 20rpx;
  color: var(--text-ghost);
  font-family: var(--font-mono);
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--border);
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.char-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-ghost);
  line-height: 1.7;
}

/* 关系边 */
.char-edges { border-top: 1rpx solid var(--border); }

.edges-section-label {
  padding: 14rpx 28rpx;
  background-color: var(--bg-sunken);
}

.edges-section-text {
  font-size: 20rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

.char-edge { border-bottom: 1rpx solid var(--border-faint); }
.char-edge:last-child { border-bottom: none; }

.char-edge-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 28rpx;
  background-color: var(--bg-card);
}

.char-edge-summary--expandable {
  background-color: var(--bg-elevated);
}

.edge-names-row { display: flex; align-items: center; gap: 12rpx; flex: 1; }

.edge-name { font-size: 26rpx; color: var(--text-secondary); font-weight: 500; }
.edge-name--source { color: var(--accent-orange); }
.edge-name--target { color: var(--text-primary); }

.edge-arrow-symbol { font-size: 22rpx; color: var(--text-void); font-family: var(--font-mono); }

.edge-summary-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.edge-base-relation {
  font-size: 22rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--border);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.edge-expand-icon {
  font-size: 20rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
}

.char-edge-interactions {
  background-color: var(--bg-sunken);
  padding: 12rpx 28rpx 16rpx;
  border-top: 1rpx solid var(--border-faint);
}

.interaction-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-faint);
}

.interaction-item:last-child { border-bottom: none; }

.ia-header { margin-bottom: 6rpx; }

.ia-action {
  font-size: 24rpx;
  color: var(--accent-red);
  font-family: var(--font-mono);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.ia-detail {
  display: block;
  font-size: 24rpx;
  color: var(--text-ghost);
  line-height: 1.7;
}

/* ── 时间线 ── */
.timeline { padding: 24rpx 28rpx; }

.timeline-item { display: flex; gap: 24rpx; }

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 24rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--text-void);
  border: 2rpx solid var(--text-ghost);
  flex-shrink: 0;
}

.timeline-dot--critical {
  background-color: var(--accent-red);
  border-color: var(--accent-red);
  box-shadow: 0 0 0 4rpx rgba(200, 57, 43, 0.25);
}

.timeline-dot--high {
  background-color: var(--accent-orange);
  border-color: var(--accent-orange);
  box-shadow: 0 0 0 4rpx rgba(200, 112, 64, 0.2);
}

.timeline-line {
  flex: 1;
  width: 1rpx;
  background: linear-gradient(to bottom, var(--text-void), transparent);
  margin-top: 4rpx;
  min-height: 48rpx;
}

.timeline-right { flex: 1; padding-bottom: 36rpx; }

.tl-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.timeline-time {
  font-size: 22rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

.tl-fuzzy-mark {
  color: var(--text-phantom);
  font-size: 20rpx;
}

.tl-importance-badge {
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-family: var(--font-mono);
}

.tl-critical {
  background-color: var(--accent-red-dim);
  color: var(--accent-red);
  border: 1rpx solid var(--accent-red-mid);
}

.tl-high {
  background-color: #2A1A10;
  color: var(--accent-orange);
  border: 1rpx solid #4A2A10;
}

.tl-normal {
  background-color: var(--bg-elevated);
  color: var(--text-phantom);
  border: 1rpx solid var(--border);
}

.tl-importance-text { font-size: 20rpx; }

.timeline-event { display: block; font-size: 30rpx; color: var(--text-secondary); font-weight: 500; line-height: 1.4; margin-bottom: 8rpx; }
.timeline-detail { display: block; font-size: 24rpx; color: var(--text-ghost); line-height: 1.7; margin-bottom: 10rpx; }

.tl-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }

.tl-tag {
  font-size: 20rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--border);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

/* ── 证据链 ── */
.evidence-nodes { padding: 8rpx 0; }

.evidence-node {
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.evidence-node:last-child { border-bottom: none; }

.evidence-node-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.evidence-node-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.evidence-type-icon {
  font-size: 34rpx;
  color: var(--accent-green);
  flex-shrink: 0;
}

.evidence-type-meta { display: flex; flex-direction: column; gap: 6rpx; }

.evidence-type-label {
  font-size: 20rpx;
  color: var(--text-ghost);
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
}

.evidence-rel-badge {
  font-size: 20rpx;
  font-family: var(--font-mono);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  display: inline-block;
}

.rel-high   { background-color: #0A1A0A; color: var(--accent-green); border: 1rpx solid var(--border-green); }
.rel-medium { background-color: #2A1A10; color: var(--accent-orange); border: 1rpx solid #4A2A10; }
.rel-low    { background-color: var(--bg-elevated); color: var(--text-phantom); border: 1rpx solid var(--border); }

.evidence-node-id {
  font-size: 22rpx;
  color: var(--text-void);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  opacity: 0.6;
}

.evidence-node-name {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.evidence-node-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-ghost);
  line-height: 1.7;
  margin-bottom: 10rpx;
}

.evidence-node-source {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.evidence-source-label {
  font-size: 20rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
}

.evidence-source-val {
  font-size: 22rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  opacity: 0.7;
}

/* 证据关联边 */
.evidence-edges { border-top: 1rpx solid var(--border); }

.evidence-edge {
  padding: 16rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.evidence-edge:last-child { border-bottom: none; }

.evidence-edge-chain {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.ev-edge-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-family: var(--font-mono);
}

.ev-edge-relation-chip {
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--border);
  border-radius: 4rpx;
  padding: 2rpx 12rpx;
}

.ev-edge-rel-label {
  font-size: 20rpx;
  color: var(--accent-orange);
  font-family: var(--font-mono);
}

.ev-edge-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-phantom);
  line-height: 1.6;
}

/* ── 证据关系图 Canvas ── */
.ev-graph-wrap { position: relative; }

.ev-canvas {
  width: 100%;
  height: 270px;
  display: block;
  background-color: #090D13;
}

.ev-hint {
  display: block;
  font-size: 20rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  text-align: center;
  padding: 12rpx 0 18rpx;
}

/* 选中节点详情卡 */
.ev-detail {
  margin: 0 28rpx 20rpx;
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  padding: 22rpx 24rpx;
  animation: evFadeIn 0.15s ease;
}

@keyframes evFadeIn {
  from { opacity: 0; transform: translateY(-6rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.ev-detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ev-detail-type-row { display: flex; align-items: center; gap: 12rpx; }

.ev-detail-icon { font-size: 30rpx; color: var(--accent-green); }

.ev-detail-type-lbl {
  font-size: 22rpx;
  color: var(--text-ghost);
  font-family: var(--font-mono);
}

.ev-detail-close {
  font-size: 38rpx;
  color: var(--text-phantom);
  padding: 0 6rpx;
  line-height: 1;
}

.ev-detail-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.ev-detail-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-ghost);
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.ev-detail-source { display: flex; align-items: center; gap: 10rpx; }

.ev-src-label {
  font-size: 20rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
}

.ev-src-val {
  font-size: 22rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  opacity: 0.75;
}

/* 关联关系文字列表 */
.ev-edge-list { border-top: 1rpx solid var(--border-faint); }

.ev-edge-item {
  padding: 16rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.ev-edge-item:last-child { border-bottom: none; }

.ev-edge-chain {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 6rpx;
}

.ev-edge-node {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.ev-edge-mid { display: flex; align-items: center; gap: 6rpx; }

.ev-edge-rel {
  font-size: 20rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  background-color: var(--bg-green-dim);
  border: 1rpx solid var(--border-green);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.ev-edge-arrow { font-size: 22rpx; color: var(--text-phantom); }

.ev-edge-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

/* ── 参考链接 ── */
.ref-list { padding: 8rpx 0; }

.ref-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.ref-item:last-child { border-bottom: none; }

.ref-icon  { font-size: 30rpx; color: var(--accent-green); opacity: 0.4; flex-shrink: 0; }
.ref-info  { flex: 1; min-width: 0; }
.ref-title { display: block; font-size: 26rpx; color: var(--text-muted);   margin-bottom: 4rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ref-url   { display: block; font-size: 20rpx; color: var(--accent-green); font-family: var(--font-mono); opacity: 0.5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ref-arrow { font-size: 34rpx; color: var(--text-void); flex-shrink: 0; }

/* ── 章节索引导航 ── */
.sec-nav {
  position: fixed;
  left: 20rpx;
  bottom: 280rpx;
  z-index: 100;
  background-color: rgba(13, 17, 23, 0.94);
  border: 1rpx solid var(--border);
  border-radius: 6rpx;
  padding: 6rpx 0;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}

.sec-nav--visible {
  opacity: 1;
  pointer-events: auto;
}

/* 章节条目（section 类型） */
.sec-nav-item {
  display: flex;
  align-items: center;
  padding: 14rpx 16rpx;
  border-left: 3rpx solid transparent;
  position: relative;
  overflow: visible;
}

.sec-nav-item--active {
  border-left-color: var(--accent-red);
}

.sec-nav-code {
  font-size: 20rpx;
  color: var(--text-void);
  font-family: var(--font-mono);
  letter-spacing: 0;
  transition: color 0.15s;
}

.sec-nav-item--active .sec-nav-code {
  color: var(--accent-red);
}

/* markdown 一级标题条目 */
.sec-nav-item--h1 {
  padding: 10rpx 16rpx;
  border-left-color: var(--text-phantom);
}

.sec-nav-item--h1 .sec-nav-code {
  font-size: 20rpx;
  color: var(--text-faint);
}

.sec-nav-item--h1.sec-nav-item--active {
  border-left-color: var(--accent-orange);
}

.sec-nav-item--h1.sec-nav-item--active .sec-nav-code {
  color: var(--accent-orange);
}

/* markdown 二级标题条目 */
.sec-nav-item--h2 {
  padding: 8rpx 16rpx 8rpx 26rpx;
  border-left-color: var(--text-phantom);
}

.sec-nav-item--h2 .sec-nav-code {
  font-size: 18rpx;
  color: var(--text-phantom);
}

.sec-nav-item--h2.sec-nav-item--active {
  border-left-color: var(--accent-orange);
}

.sec-nav-item--h2.sec-nav-item--active .sec-nav-code {
  color: var(--accent-orange);
}

/* 标签浮层（仅 active 时显示，右侧弹出） */
.sec-nav-label-wrap {
  position: absolute;
  left: 100%;
  top: 50%;
  transform: translateY(-50%);
  margin-left: 12rpx;
  background-color: rgba(13, 17, 23, 0.96);
  border: 1rpx solid var(--border);
  border-radius: 4rpx;
  padding: 6rpx 14rpx;
  white-space: nowrap;
  pointer-events: none;
  opacity: 0;
}

.sec-nav-item--active .sec-nav-label-wrap {
  opacity: 1;
}

.sec-nav-label {
  font-size: 20rpx;
  color: var(--text-muted);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

/* ── 底部操作栏 ── */
.action-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  background-color: var(--bg-card);
  border-top: 1rpx solid var(--border);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
}

.action-btn--share   { background-color: var(--bg-elevated); color: var(--text-muted); border: 1rpx solid var(--border); }
.action-btn--collect { background-color: var(--accent-red-dim); color: var(--accent-red); border: 1rpx solid var(--accent-red-mid); }
.action-btn--report  { background-color: transparent; color: var(--text-phantom); border: 1rpx solid var(--border-faint); }
.action-btn--edit    { background-color: var(--bg-green-dim); color: var(--accent-green); border: 1rpx solid var(--border-green); }
.action-icon { font-size: 30rpx; }

/* ── 作者信息 ── */
.info-row--author { align-items: center; }
.author-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}
.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border);
}
.author-avatar-placeholder {
  font-size: 28rpx;
  color: var(--text-phantom);
}
.author-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.author-level {
  font-size: 22rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  background-color: var(--bg-green-dim);
  border: 1rpx solid var(--border-green);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

/* ── 讨论区 ── */
.comments-panel {
  margin: 24rpx 24rpx 0;
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  background-color: var(--bg-card);
}

.comment-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
  background-color: var(--bg-sunken);
}

.comment-input {
  flex: 1;
  height: 64rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--border);
  border-radius: 6rpx;
  padding: 0 20rpx;
}

.comment-submit-btn {
  flex-shrink: 0;
  padding: 14rpx 24rpx;
  background-color: var(--accent-red);
  border-radius: 6rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
}

.comment-submit-btn--loading { opacity: 0.6; }

.comment-list { padding: 0; }

.comment-loading { padding: 40rpx; text-align: center; }
.comment-loading-text { font-size: 20rpx; color: var(--accent-green); font-family: var(--font-mono); letter-spacing: 4rpx; }

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.comment-item:last-child { border-bottom: none; }

.comment-avatar { flex-shrink: 0; }

.comment-avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 1rpx solid var(--folk-border);
}

.comment-avatar-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-void);
}

.comment-body { flex: 1; min-width: 0; }

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.comment-username { font-size: 26rpx; color: var(--text-muted); font-weight: 600; }
.comment-time { font-size: 20rpx; color: var(--text-phantom); font-family: var(--font-mono); }
.comment-content { font-size: 28rpx; color: var(--text-secondary); line-height: 1.7; }

.comment-empty { padding: 48rpx 28rpx; text-align: center; }

.comment-empty-text {
  font-size: 24rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

.comment-load-more {
  display: flex;
  justify-content: center;
  padding: 24rpx;
  border-top: 1rpx solid var(--border-faint);
}

.comment-load-more-text {
  font-size: 22rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

/* ── 加载中页 ── */
.loading-page {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-base);
}

.loading-terminal { display: flex; align-items: center; gap: 8rpx; }

.terminal-text {
  font-size: 26rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

.terminal-cursor {
  width: 16rpx;
  height: 30rpx;
  background-color: var(--accent-green);
  animation: blink 1s step-end infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}
