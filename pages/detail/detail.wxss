/* pages/detail/detail.wxss —— 所有色值全部走 var() */

/* ── 档案编号横幅 ── */
.archive-banner {
  background-color: var(--bg-base);
  padding: 24rpx 32rpx;
}

.banner-grid-line {
  height: 1rpx;
  background: repeating-linear-gradient(
    90deg,
    var(--border) 0px, var(--border) 8px,
    transparent 8px, transparent 16px
  );
}

.banner-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.banner-no {
  display: block;
  font-size: 22rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
  margin-bottom: 6rpx;
}

.banner-label {
  display: block;
  font-size: 16rpx;
  color: var(--text-void);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

/* 类型徽章（detail 专用，稍大） */
.banner-type-badge {
  padding: 8rpx 20rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  font-weight: 700;
}

.badge-type-folk     { background-color: var(--folk-bg);     color: var(--folk-text);     border: 1rpx solid var(--folk-border); }
.badge-type-official { background-color: var(--official-bg); color: var(--official-text); border: 1rpx solid var(--official-border); }
.badge-type-third    { background-color: var(--third-bg);    color: var(--third-text);    border: 1rpx solid var(--third-border); }

/* ── 标题区 ── */
.title-section {
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.title-main {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.title-status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
}

.badge-status-ongoing {
  background-color: var(--accent-red-dim);
  color: var(--accent-red);
  border: 1rpx solid var(--accent-red-mid);
}

.badge-status-closed {
  background-color: var(--bg-elevated);
  color: var(--text-ghost);
  border: 1rpx solid var(--border);
}

.status-pulse { animation: pulse 1.5s ease-in-out infinite; }

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.3; }
}

.status-pulse-static { opacity: 0.6; }

.title-meta { display: flex; align-items: center; gap: 12rpx; }

.meta-lang {
  font-size: 20rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  border: 1rpx solid var(--border);
  padding: 2rpx 10rpx;
  border-radius: 3rpx;
}

.meta-dot   { color: var(--border); }
.meta-views { font-size: 20rpx; color: var(--text-phantom); font-family: var(--font-mono); }

/* ── 通用面板容器 ── */
.info-panel,
.content-panel,
.graph-panel,
.timeline-panel,
.evidence-panel,
.refs-panel {
  margin: 24rpx 24rpx 0;
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  background-color: var(--bg-card);
}

.panel-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  background-color: var(--bg-sunken);
  border-bottom: 1rpx solid var(--border);
}

.panel-header-code {
  font-size: 20rpx;
  color: var(--accent-red);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  font-weight: 700;
}

.panel-header-text {
  font-size: 24rpx;
  color: var(--text-muted);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

/* ── 基础信息面板 ── */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 18rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.info-row:last-child { border-bottom: none; }

.info-key { font-size: 24rpx; color: var(--text-ghost);   font-family: var(--font-mono); flex-shrink: 0; margin-right: 24rpx; }
.info-val { font-size: 24rpx; color: var(--text-secondary); font-family: var(--font-mono); text-align: right; flex: 1; }
.info-val--unknown { color: var(--text-phantom); font-style: italic; }

/* ── 正文内容 ── */
.content-body  { padding: 28rpx; }

.content-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.9;
  letter-spacing: 1rpx;
}

.content-end-marker { padding: 16rpx 28rpx 24rpx; text-align: right; }

.end-marker-text {
  font-size: 18rpx;
  color: var(--text-void);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
}

/* ── 人物关系 ── */
.character-list { padding: 16rpx 0; }

.character-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
  gap: 20rpx;
}

.character-item:last-child { border-bottom: none; }

.character-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--folk-border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.character-initial { font-size: 30rpx; color: var(--text-muted); font-family: var(--font-mono); }
.character-info    { flex: 1; }
.character-name    { display: block; font-size: 28rpx; color: var(--text-primary); font-weight: 600; margin-bottom: 6rpx; }
.character-role    { display: block; font-size: 22rpx; color: var(--accent-green);  font-family: var(--font-mono); margin-bottom: 8rpx; }
.character-desc    { display: block; font-size: 22rpx; color: var(--text-ghost);    line-height: 1.6; }

.character-status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  flex-shrink: 0;
}

/* ── 时间线 ── */
.timeline { padding: 24rpx 28rpx; }

.timeline-item { display: flex; gap: 24rpx; min-height: 80rpx; }

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 24rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--text-void);
  border: 2rpx solid var(--text-ghost);
  flex-shrink: 0;
}

.timeline-dot--first {
  background-color: var(--accent-red);
  border-color: var(--accent-red);
  box-shadow: 0 0 0 4rpx rgba(200, 57, 43, 0.2);
}

.timeline-line {
  flex: 1;
  width: 1rpx;
  background: linear-gradient(to bottom, var(--text-void), transparent);
  margin-top: 4rpx;
  min-height: 48rpx;
}

.timeline-right { flex: 1; padding-bottom: 36rpx; }

.timeline-time  { display: block; font-size: 20rpx; color: var(--accent-green); font-family: var(--font-mono); letter-spacing: 2rpx; margin-bottom: 8rpx; }
.timeline-event { display: block; font-size: 28rpx; color: var(--text-secondary); font-weight: 500; line-height: 1.4; margin-bottom: 8rpx; }
.timeline-detail{ display: block; font-size: 22rpx; color: var(--text-ghost);     line-height: 1.7; }

/* ── 证据链 ── */
.evidence-list { padding: 8rpx 0; }

.evidence-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.evidence-item:last-child { border-bottom: none; }

.evidence-index { font-size: 28rpx; color: var(--accent-red); font-family: var(--font-mono); font-weight: 700; flex-shrink: 0; min-width: 40rpx; }
.evidence-content { flex: 1; }
.evidence-title  { display: block; font-size: 28rpx; color: var(--text-secondary); font-weight: 500; margin-bottom: 8rpx; }
.evidence-desc   { display: block; font-size: 22rpx; color: var(--text-ghost); line-height: 1.6; margin-bottom: 12rpx; }

.evidence-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }

.evidence-tag {
  font-size: 18rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  background-color: var(--bg-green-dim);
  border: 1rpx solid var(--border-green);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.evidence-credibility { display: flex; flex-direction: column; align-items: center; gap: 4rpx; flex-shrink: 0; }
.credibility-label    { font-size: 16rpx; color: var(--text-phantom); font-family: var(--font-mono); }
.credibility-value    { font-size: 24rpx; color: var(--accent-orange); font-family: var(--font-mono); font-weight: 700; }

/* ── 参考链接 ── */
.ref-list { padding: 8rpx 0; }

.ref-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.ref-item:last-child { border-bottom: none; }

.ref-icon  { font-size: 28rpx; color: var(--accent-green); opacity: 0.4; flex-shrink: 0; }
.ref-info  { flex: 1; min-width: 0; }
.ref-title { display: block; font-size: 24rpx; color: var(--text-muted);   margin-bottom: 4rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ref-url   { display: block; font-size: 18rpx; color: var(--accent-green); font-family: var(--font-mono); opacity: 0.5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ref-arrow { font-size: 32rpx; color: var(--text-void); flex-shrink: 0; }

/* ── 底部操作栏 ── */
.action-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  background-color: var(--bg-card);
  border-top: 1rpx solid var(--border);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
}

.action-btn--share   { background-color: var(--bg-elevated); color: var(--text-muted); border: 1rpx solid var(--border); }
.action-btn--collect { background-color: var(--accent-red-dim); color: var(--accent-red); border: 1rpx solid var(--accent-red-mid); }
.action-icon { font-size: 28rpx; }

/* ── 加载中页 ── */
.loading-page {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-base);
}

.loading-terminal { display: flex; align-items: center; gap: 8rpx; }

.terminal-text {
  font-size: 24rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

.terminal-cursor {
  width: 16rpx;
  height: 30rpx;
  background-color: var(--accent-green);
  animation: blink 1s step-end infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}
