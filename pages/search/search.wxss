/* pages/search/search.wxss */

.search-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  padding: 0 20rpx;
  gap: 12rpx;
  height: 80rpx;
}

.search-prefix { font-size: 28rpx; color: var(--accent-green); font-family: var(--font-mono); flex-shrink: 0; }
.search-input  { flex: 1; font-size: 26rpx; color: var(--text-primary); font-family: var(--font-mono); height: 80rpx; line-height: 80rpx; }
.search-clear  { font-size: 32rpx; color: var(--text-phantom); flex-shrink: 0; padding: 0 8rpx; }

.search-btn {
  background-color: var(--accent-red);
  color: var(--text-primary);
  padding: 18rpx 28rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.section { padding: 28rpx 24rpx 16rpx; }

.section-title { display: flex; align-items: center; gap: 14rpx; margin-bottom: 20rpx; }
.section-code  { font-size: 18rpx; color: var(--accent-red);   font-family: var(--font-mono); letter-spacing: 3rpx; font-weight: 700; }
.section-label { font-size: 24rpx; color: var(--text-faint);   font-family: var(--font-mono); letter-spacing: 2rpx; }

.tag-cloud { display: flex; flex-wrap: wrap; gap: 16rpx; }

.tag-item {
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  color: var(--text-faint);
  padding: 12rpx 24rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-family: var(--font-mono);
}

.region-list { display: flex; flex-direction: column; gap: 2rpx; }

.region-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 6rpx;
}

.region-name  { font-size: 26rpx; color: var(--text-secondary); }
.region-count { font-size: 20rpx; color: var(--text-phantom); font-family: var(--font-mono); }

/* 搜索结果区 */
.results-wrap { padding-top: 8rpx; }

.results-header {
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.results-count   { font-size: 22rpx; color: var(--text-ghost);   font-family: var(--font-mono); }
.results-keyword { font-size: 22rpx; color: var(--accent-green);  font-family: var(--font-mono); }

/* 结果卡片（继承全局 + 本页补充）*/
.result-card {
  margin: 16rpx 24rpx;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  display: flex;
  position: relative;
}

.card-side-bar     { width: 6rpx; flex-shrink: 0; }
.card-side-bar--0  { background-color: var(--folk-bar); }
.card-side-bar--1  { background-color: var(--official-bar); }
.card-side-bar--2  { background-color: var(--third-bar); }

.card-body     { flex: 1; padding: 24rpx 24rpx 20rpx 28rpx; }
.card-meta-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }

.archive-no {
  font-size: 18rpx;
  color: var(--accent-green);
  opacity: 0.5;
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

.badge               { display: inline-block; padding: 4rpx 12rpx; border-radius: 4rpx; font-size: 18rpx; font-family: var(--font-mono); letter-spacing: 2rpx; font-weight: 600; }
.badge-type-folk     { background-color: var(--folk-bg);     color: var(--folk-text);     border: 1rpx solid var(--folk-border); }
.badge-type-official { background-color: var(--official-bg); color: var(--official-text); border: 1rpx solid var(--official-border); }
.badge-type-third    { background-color: var(--third-bg);    color: var(--third-text);    border: 1rpx solid var(--third-border); }

.card-title   { font-size: 30rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 10rpx; }
.card-preview { font-size: 22rpx; color: var(--text-ghost); line-height: 1.6; margin-bottom: 16rpx; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.card-footer  { display: flex; justify-content: space-between; align-items: center; }

.status-badge        { font-size: 20rpx; font-family: var(--font-mono); }
.badge-status-ongoing{ color: var(--accent-red); }
.badge-status-closed { color: var(--text-phantom); }
.card-date           { font-size: 18rpx; color: var(--text-phantom); font-family: var(--font-mono); }

.empty-icon      { font-size: 96rpx; color: var(--border); display: block; text-align: center; margin-bottom: 24rpx; margin-top: 80rpx; }
.empty-state-text{ font-size: 26rpx; color: var(--text-phantom); font-family: var(--font-mono); letter-spacing: 2rpx; text-align: center; }
