<!-- pages/search/search.wxml -->
<view class="page-container">

  <!-- 搜索框 -->
  <view class="search-wrap">
    <view class="search-box">
      <text class="search-prefix">></text>
      <input
        class="search-input"
        placeholder="检索关键词、地点、事件..."
        placeholder-style="color: #6A6A6A; font-family: 'Courier New', monospace;"
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
      <view class="search-clear" bindtap="onClear" wx:if="{{keyword}}">
        <text>×</text>
      </view>
    </view>
    <view class="search-btn" bindtap="onSearch">
      <text>检索</text>
    </view>
  </view>

  <!-- 搜索中 loading -->
  <view class="search-loading" wx:if="{{loading}}">
    <text class="loading-text">SEARCHING...</text>
  </view>

  <!-- 未搜索时提示 -->
  <view class="empty-state" wx:elif="{{!searched}}">
    <text class="empty-icon">⬡</text>
    <text class="empty-state-text">输入关键词开始检索</text>
  </view>

  <!-- 搜索结果 -->
  <view class="results-wrap" wx:elif="{{searched && !loading}}">
    <view class="results-header">
      <text class="results-count">找到 {{resultList.length}} 条记录</text>
      <text class="results-keyword">「{{keyword}}」</text>
    </view>

    <view wx:if="{{resultList.length > 0}}">
      <view
        class="archive-card result-card"
        wx:for="{{resultList}}"
        wx:key="id"
        bindtap="onCardTap"
        data-id="{{item.id}}"
      >
        <view class="card-side-bar card-side-bar--{{item.type}}"></view>
        <view class="card-body">
          <view class="card-meta-row">
            <text class="archive-no">{{item.archiveNo}}</text>
            <text class="badge {{item.typeInfo.className}}">{{item.typeInfo.code}}</text>
          </view>
          <view class="card-title {{item.statusInfo.className === 'badge-status-ongoing' ? 'title-shiver' : ''}}">{{item.title}}</view>
          <view class="card-preview">{{item.contentPreview}}</view>
          <view class="card-footer">
            <view class="status-badge {{item.statusInfo.className}}">
              <text>{{item.statusInfo.dot}} {{item.statusInfo.label}}</text>
            </view>
            <view class="card-footer-right">
              <text class="card-date">{{item.occurredAtFmt}}</text>
              <text class="card-views">◎ {{item.view_count || 0}}</text>
              <view class="location-info" wx:if="{{item.location_desc}}">
                <text class="location-icon">◎</text>
                <text class="location-text">{{item.location_desc}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-icon">⬡</text>
      <text class="empty-state-text">未找到相关档案记录\n尝试更换关键词</text>
    </view>
  </view>

</view>
