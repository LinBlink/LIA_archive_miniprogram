/* pages/my-archives/my-archives.wxss */

/* ── 页面头部 ── */
.page-header {
  padding: 40rpx 32rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.page-header-eyebrow {
  display: block;
  font-size: 20rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.page-header-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

/* 复用 index 页卡片样式，此处仅补充删除按钮 */
.archive-card {
  margin: 0 24rpx 24rpx;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  display: flex;
  position: relative;
}

.card-side-bar { width: 6rpx; flex-shrink: 0; }
.card-side-bar--0 { background-color: var(--folk-bar); }
.card-side-bar--1 { background-color: var(--official-bar); }
.card-side-bar--2 { background-color: var(--third-bar); }

.card-body { flex: 1; padding: 24rpx 24rpx 24rpx 28rpx; min-width: 0; }

.card-meta-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx; }
.archive-no { font-size: 20rpx; color: var(--accent-green); opacity: 0.5; font-family: var(--font-mono); letter-spacing: 3rpx; }
.card-badges { display: flex; gap: 8rpx; }
.lang-badge { background-color: var(--bg-elevated); color: var(--text-void); border: 1rpx solid var(--border); display: inline-block; padding: 4rpx 12rpx; border-radius: 4rpx; font-size: 20rpx; font-family: var(--font-mono); letter-spacing: 2rpx; font-weight: 600; }
.card-title { font-size: 34rpx; font-weight: 600; color: var(--text-primary); line-height: 1.4; margin-bottom: 12rpx; }
.card-preview { font-size: 26rpx; color: var(--text-ghost); line-height: 1.7; margin-bottom: 20rpx; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.card-footer { display: flex; justify-content: space-between; align-items: center; }
.footer-left { display: flex; flex-direction: column; gap: 8rpx; }
.status-badge { display: inline-flex; align-items: center; gap: 6rpx; font-size: 22rpx; font-family: var(--font-mono); }
.status-dot-inline { font-size: 18rpx; }
.badge-status-ongoing { color: var(--accent-red); }
.badge-status-closed  { color: var(--text-phantom); }
.location-info { display: flex; align-items: center; gap: 6rpx; }
.location-icon { font-size: 20rpx; color: var(--accent-green); }
.location-text { font-size: 22rpx; color: var(--text-ghost); max-width: 260rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.card-date { font-size: 22rpx; color: var(--text-phantom); font-family: var(--font-mono); }

.card-delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  flex-shrink: 0;
  font-size: 30rpx;
  color: var(--accent-red);
  border-left: 1rpx solid var(--border-faint);
  background-color: var(--bg-sunken);
}

.skeleton-card { margin: 0 24rpx 24rpx; background-color: var(--bg-card); border: 1rpx solid var(--border); border-radius: 8rpx; padding: 28rpx; }
.skeleton-line { height: 28rpx; background: linear-gradient(90deg, var(--bg-elevated) 25%, var(--border) 50%, var(--bg-elevated) 75%); background-size: 200% 100%; border-radius: 4rpx; margin-bottom: 16rpx; animation: shimmer 1.5s infinite; }
.skeleton-line--short { width: 40%; }
.skeleton-line--mid   { width: 70%; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

.load-more, .no-more { display: flex; justify-content: center; padding: 40rpx; }
.load-more-text { font-size: 24rpx; color: var(--accent-green); font-family: var(--font-mono); letter-spacing: 4rpx; }
.no-more-text { font-size: 22rpx; color: var(--text-void); font-family: var(--font-mono); letter-spacing: 4rpx; }
.empty-icon { font-size: 98rpx; color: var(--border); display: block; text-align: center; margin-bottom: 24rpx; }
