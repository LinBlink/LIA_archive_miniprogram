/* pages/index/index.wxss —— 所有色值全部走 var() */

/* ── 系统状态顶栏 ── */
.sys-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
  background-color: var(--bg-base);
}

.sys-label {
  display: block;
  font-size: 18rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
  margin-bottom: 6rpx;
}

.sys-id {
  display: block;
  font-size: 16rpx;
  color: var(--text-void);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

.sys-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: var(--text-void);
}

.status-dot--active {
  background-color: var(--accent-green);
  box-shadow: 0 0 0 4rpx rgba(74, 124, 111, 0.2);
}

.status-text {
  font-size: 18rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

/* ── 统计概览栏 ── */
.stats-bar {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background-color: var(--bg-card);
  border-bottom: 1rpx solid var(--border);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: var(--font-mono);
  line-height: 1.1;
}

.stat-num.ongoing { color: var(--accent-red); }

.stat-label {
  font-size: 20rpx;
  color: var(--text-faint);
  margin-top: 6rpx;
  letter-spacing: 2rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: var(--border);
}

/* ── 筛选滚动栏 ── */
.filter-scroll {
  white-space: nowrap;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.filter-row {
  display: inline-flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 16rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 6rpx;
  font-size: 24rpx;
  color: var(--text-faint);
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
  white-space: nowrap;
}

.filter-chip--active {
  background-color: var(--bg-elevated);
  border-color: var(--accent-red);
  color: var(--text-primary);
}

.chip-dot { width: 10rpx; height: 10rpx; border-radius: 50%; }
.chip-dot--red { background-color: var(--accent-red); }

/* ── 档案列表 ── */
.archive-list { padding: 24rpx 0; }

/* ── 档案卡片 ── */
.archive-card {
  margin: 0 24rpx 24rpx;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  display: flex;
  position: relative;
}

.card-side-bar { width: 6rpx; flex-shrink: 0; }
.card-side-bar--0 { background-color: var(--folk-bar); }
.card-side-bar--1 { background-color: var(--official-bar); }
.card-side-bar--2 { background-color: var(--third-bar); }

.card-body { flex: 1; padding: 24rpx 24rpx 24rpx 28rpx; min-width: 0; }

/* 元信息行 */
.card-meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.archive-no {
  font-size: 18rpx;
  color: var(--accent-green);
  opacity: 0.5;
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

.card-badges { display: flex; gap: 8rpx; }

/* badge 复用全局 app.wxss 定义，此处补充 lang-badge */
.lang-badge {
  background-color: var(--bg-elevated);
  color: var(--text-void);
  border: 1rpx solid var(--border);
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 18rpx;
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  font-weight: 600;
}

/* 标题 */
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

/* 正文预览 */
.card-preview {
  font-size: 24rpx;
  color: var(--text-ghost);
  line-height: 1.7;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 底部信息行 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-left { display: flex; flex-direction: column; gap: 8rpx; }

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  font-family: var(--font-mono);
}

.status-dot-inline { font-size: 16rpx; }
.badge-status-ongoing { color: var(--accent-red); }
.badge-status-closed  { color: var(--text-phantom); }

.location-info { display: flex; align-items: center; gap: 6rpx; }
.location-icon { font-size: 18rpx; color: var(--accent-green); }
.location-text {
  font-size: 20rpx;
  color: var(--text-ghost);
  max-width: 280rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.footer-right { display: flex; flex-direction: column; align-items: flex-end; }
.card-date {
  font-size: 20rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
}

/* 私密标记 */
.private-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background-color: var(--bg-private);
  border: 1rpx solid var(--border-private);
  border-radius: 4rpx;
  padding: 4rpx 10rpx;
  font-size: 18rpx;
  color: var(--text-private);
  font-family: var(--font-mono);
}

/* ── 骨架屏 ── */
.skeleton-card {
  margin: 0 24rpx 24rpx;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  padding: 28rpx;
}

.skeleton-line {
  height: 28rpx;
  background: linear-gradient(90deg, var(--bg-elevated) 25%, var(--border) 50%, var(--bg-elevated) 75%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-line--short { width: 40%; }
.skeleton-line--mid   { width: 70%; }

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ── 加载更多 / 结尾 ── */
.load-more, .no-more {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

.load-more-text {
  font-size: 22rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
}

.no-more-text {
  font-size: 20rpx;
  color: var(--text-void);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
}

/* ── 空状态 ── */
.empty-icon {
  font-size: 96rpx;
  color: var(--border);
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

/* ── FAB 浮动按钮 ── */
.fab {
  position: fixed;
  bottom: 160rpx;
  right: 32rpx;
  background-color: var(--accent-red);
  border-radius: 48rpx;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 8rpx 32rpx rgba(200, 57, 43, 0.4);
  z-index: 100;
}

.fab-icon  { font-size: 36rpx; color: var(--text-primary); font-weight: 300; line-height: 1; }
.fab-label { font-size: 26rpx; color: var(--text-primary); font-family: var(--font-mono); letter-spacing: 1rpx; }
