<!-- pages/index/index.wxml - 档案库主页 -->
<view class="page-container">

  <!-- ══ 顶部系统状态栏 ══ -->
  <view class="sys-header">
    <view class="sys-header-left">
      <text class="sys-label">閾界档案室 LIMINALITY ARCHIVE SYSTEM</text>
      <text class="sys-id">版本号 V0.2</text>
    </view>
    <view class="sys-status">
      <view class="status-dot {{isOnline ? 'status-dot--active' : ''}}"></view>
      <text class="status-text">{{isOnline ? '服务器在线' : '服务器离线'}}</text>
    </view>
  </view>

  <view style="text-align:center; font-size:22rpx; color:var(--accent-red); padding:12rpx 0;" wx:if="{{!isOnline}}">服务器离线，当前展示示例内容</view>

  <!-- ══ 档案统计概览 ══ -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">档案总数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num ongoing">{{ongoingCount}}</text>
      <text class="stat-label">调查中</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{closedCount}}</text>
      <text class="stat-label">已结案</text>
    </view>
  </view>

  <!-- ══ 筛选标签栏：类型/状态 ══ -->
  <scroll-view class="filter-scroll" scroll-x>
    <view class="filter-row">
      <view class="filter-chip {{activeFilter === 'all' ? 'filter-chip--active' : ''}}" bindtap="onFilterChange" data-value="all">全部</view>
      <view class="filter-chip {{activeFilter === 'ongoing' ? 'filter-chip--active' : ''}}" bindtap="onFilterChange" data-value="ongoing">
        <view class="chip-dot chip-dot--red"></view>调查中
      </view>
      <view class="filter-chip {{activeFilter === 'closed' ? 'filter-chip--active' : ''}}" bindtap="onFilterChange" data-value="closed">已结案</view>
      <view class="filter-chip {{activeFilter === '0' ? 'filter-chip--active' : ''}}" bindtap="onFilterChange" data-value="0">民间档案</view>
      <view class="filter-chip {{activeFilter === '1' ? 'filter-chip--active' : ''}}" bindtap="onFilterChange" data-value="1">官方档案</view>
      <view class="filter-chip {{activeFilter === '2' ? 'filter-chip--active' : ''}}" bindtap="onFilterChange" data-value="2">第三方</view>
    </view>
  </scroll-view>

  <!-- ══ 档案卡片列表 ══ -->
  <view class="archive-list">

    <!-- 加载骨架屏 -->
    <block wx:if="{{loading}}">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="index">
        <view class="skeleton-line skeleton-line--short"></view>
        <view class="skeleton-line"></view>
        <view class="skeleton-line skeleton-line--mid"></view>
      </view>
    </block>

    <!-- 档案卡片 -->
    <block wx:elif="{{archiveList.length > 0}}">
      <view class="archive-card" wx:for="{{archiveList}}" wx:key="id" bindtap="onCardTap" data-id="{{item.id}}">

        <!-- 封面图（取自正文第一张图片），置于顶部横跨全宽 -->
        <image
          wx:if="{{item.coverImage && !item.coverError}}"
          class="card-cover"
          src="{{item.coverImage}}"
          mode="aspectFill"
          lazy-load
          binderror="onCoverError"
          data-id="{{item.id}}"
        />

        <!-- 竖条 + 正文信息 -->
        <view class="card-main">
        <view class="card-side-bar card-side-bar--{{item.type}}"></view>

        <view class="card-body">
          <view class="card-meta-row">
            <text class="archive-no">{{item.archiveNo}}</text>
            <view class="card-badges">
              <text class="badge {{item.typeInfo.className}}">{{item.typeInfo.code}}</text>
              <text class="badge lang-badge">{{item.langCode}}</text>
            </view>
          </view>

          <view class="card-title {{item.statusInfo.className === 'badge-status-ongoing' ? 'title-shiver' : ''}}">{{item.title}}</view>
          <view class="card-preview">{{item.contentPreview}}</view>

          <view class="card-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text class="card-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
          </view>

          <view class="card-footer">
            <view class="footer-left">
              <view class="status-badge {{item.statusInfo.className}}">
                <text class="status-dot-inline">{{item.statusInfo.dot}}</text>
                <text>{{item.statusInfo.label}}</text>
              </view>
              <view class="location-info" wx:if="{{item.location_desc}}">
                <text class="location-icon">◎</text>
                <text class="location-text">{{item.location_desc}}</text>
              </view>
            </view>
            <view class="footer-right">
              <text class="card-date">{{item.occurredAtFmt}}</text>
              <text class="card-views">◎ {{item.view_count || 0}}</text>
            </view>
          </view>

          <view class="private-badge" wx:if="{{item.is_private === 1}}">
            <text>⚿ 私密</text>
          </view>
        </view>
        </view><!-- /card-main -->
      </view>

      <view class="load-more" bindtap="onLoadMore" wx:if="{{hasMore}}">
        <text class="load-more-text">— 载入更多档案 —</text>
      </view>
      <view class="no-more" wx:else>
        <text class="no-more-text">// END OF RECORDS //</text>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:else>
      <text class="empty-icon">⬡</text>
      <text class="empty-state-text">当前分类下\n暂无档案记录</text>
    </view>

  </view>

  <!-- 新建档案浮动按钮 -->
  <view class="fab" bindtap="onCreateTap">
    <text class="fab-icon">+</text>
    <text class="fab-label">录入档案</text>
  </view>

</view>
