/* pages/login/login.wxss */

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
  min-height: 100vh;
}

.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.login-logo {
  font-size: 98rpx;
  color: var(--accent-red);
  line-height: 1;
  margin-bottom: 24rpx;
}

.login-system-name {
  font-size: 20rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.login-title {
  font-size: 54rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.login-tagline {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
}

.login-card {
  width: 100%;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 48rpx;
}

.login-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background-color: var(--bg-sunken);
  border-bottom: 1rpx solid var(--border);
}

.login-card-code {
  font-size: 20rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
}

.login-card-label {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

/* ── Tab 切换 ── */

.auth-tabs {
  display: flex;
  border-bottom: 1rpx solid var(--border);
}

.auth-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-muted);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

.auth-tab--active {
  color: var(--accent-green);
  border-bottom: 2rpx solid var(--accent-green);
}

/* ── 卡片正文 ── */

.login-card-body {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── 登录 / 注册切换 ── */

.mode-switch {
  display: flex;
  width: 100%;
  background-color: var(--bg-sunken);
  border-radius: 6rpx;
  padding: 4rpx;
  margin-bottom: 36rpx;
  box-sizing: border-box;
}

.mode-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--text-muted);
  border-radius: 4rpx;
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

.mode-btn--active {
  background-color: var(--bg-card);
  color: var(--text-primary);
}

/* ── 输入组 ── */

.input-group {
  width: 100%;
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 20rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 3rpx;
  margin-bottom: 10rpx;
}

.auth-input {
  width: 100%;
  background-color: var(--bg-sunken);
  border: 1rpx solid var(--border);
  border-radius: 6rpx;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  font-family: var(--font-mono);
  box-sizing: border-box;
}

/* ── 主按钮 ── */

.wx-login-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background-color: var(--accent-red);
  border-radius: 6rpx;
  padding: 28rpx 0;
  border: none;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

.wx-login-btn--loading {
  opacity: 0.6;
}

.wx-login-icon {
  font-size: 34rpx;
  color: var(--text-primary);
  line-height: 1;
}

.wx-login-text {
  font-size: 32rpx;
  color: var(--text-primary);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

.login-prompt {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.login-prompt-sub {
  font-size: 26rpx;
  color: var(--text-ghost);
  margin-bottom: 48rpx;
  text-align: center;
  line-height: 1.6;
}

.login-tip {
  font-size: 22rpx;
  color: var(--text-phantom);
  text-align: center;
  line-height: 1.6;
}

/* ── 功能预览 ── */

.login-features {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 60rpx;
}

.login-feature-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border-faint);
  border-radius: 6rpx;
}

.feature-dot {
  font-size: 30rpx;
  color: var(--accent-green);
  flex-shrink: 0;
}

.feature-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.login-footer {
  margin-top: auto;
  padding-top: 40rpx;
}

.login-footer-text {
  font-size: 20rpx;
  color: var(--text-void);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
}
