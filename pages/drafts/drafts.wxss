/* pages/drafts/drafts.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-base);
  padding-bottom: 60rpx;
}

/* ── 头部 ── */
.drafts-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 40rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.drafts-eyebrow {
  display: block;
  font-size: 20rpx;
  color: var(--accent-green);
  font-family: var(--font-mono);
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.drafts-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

.drafts-count-badge {
  background-color: var(--accent-red-dim);
  border: 1rpx solid var(--accent-red-mid);
  border-radius: 20rpx;
  padding: 4rpx 18rpx;
}

.drafts-count {
  font-size: 26rpx;
  color: var(--accent-red);
  font-family: var(--font-mono);
  font-weight: 700;
}

/* ── 本地存储提示 ── */
.drafts-notice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 24rpx 0;
  padding: 16rpx 20rpx;
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--border-faint);
  border-left: 3rpx solid var(--accent-orange);
  border-radius: 6rpx;
}

.drafts-notice-icon {
  font-size: 24rpx;
  color: var(--accent-orange);
  flex-shrink: 0;
}

.drafts-notice-text {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

/* ── 工具栏 ── */
.drafts-toolbar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border-faint);
}

.toolbar-btn {
  padding: 12rpx 24rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
}

.toolbar-btn--new {
  background-color: var(--accent-red);
  color: var(--text-primary);
}

.toolbar-btn--clear {
  background-color: transparent;
  color: var(--text-muted);
  border: 1rpx solid var(--border);
}

/* ── 草稿卡片 ── */
.drafts-list {
  padding: 16rpx 0;
}

.draft-card {
  margin: 0 24rpx 16rpx;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.draft-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 4rpx;
  background-color: var(--folk-bar);
}

.draft-card-inner {
  padding: 24rpx 24rpx 20rpx 32rpx;
}

.draft-top-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.draft-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}

.draft-time {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  margin-top: 4rpx;
}

.draft-preview {
  display: block;
  font-size: 26rpx;
  color: var(--text-ghost);
  line-height: 1.6;
  margin-bottom: 16rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.draft-preview--empty {
  color: var(--text-phantom);
  font-style: italic;
}

.draft-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.draft-meta {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.draft-meta-item {
  font-size: 22rpx;
  color: var(--text-phantom);
  font-family: var(--font-mono);
  background-color: var(--bg-elevated);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.draft-delete-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.draft-delete-icon {
  font-size: 34rpx;
  color: var(--text-phantom);
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx 80rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: var(--text-phantom);
  margin-bottom: 24rpx;
}

.empty-state-text {
  font-size: 30rpx;
  color: var(--text-muted);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.empty-state-sub {
  font-size: 26rpx;
  color: var(--text-phantom);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.empty-new-btn {
  background-color: var(--accent-red);
  color: var(--text-primary);
  padding: 20rpx 48rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}
