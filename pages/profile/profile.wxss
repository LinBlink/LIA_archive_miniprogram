/* pages/profile/profile.wxss */

.profile-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 48rpx 32rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
  background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-base) 100%);
}

.user-avatar-wrap { position: relative; flex-shrink: 0; }

.user-avatar {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid var(--folk-border);
}

.user-avatar-placeholder {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background-color: var(--bg-card);
  border: 2rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
}

.avatar-icon { font-size: 50rpx; color: var(--text-void); }

.user-level-badge {
  position: absolute; bottom: -4rpx; right: -4rpx;
  background-color: var(--accent-red);
  color: var(--text-primary);
  font-size: 18rpx; font-family: var(--font-mono);
  padding: 2rpx 8rpx; border-radius: 10rpx;
}

.user-name    { display: block; font-size: 38rpx; font-weight: 600; color: var(--text-primary);   margin-bottom: 8rpx; }
.user-id-str  { display: block; font-size: 22rpx; color: var(--text-void);    font-family: var(--font-mono); letter-spacing: 2rpx; margin-bottom: 12rpx; }
.user-tag-row { display: flex; gap: 10rpx; }

.user-name-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.edit-profile-btn {
  width: 48rpx; height: 48rpx;
  display: flex; align-items: center; justify-content: center;
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--border);
  border-radius: 50%;
  flex-shrink: 0;
}
.edit-profile-icon { font-size: 24rpx; color: var(--text-muted); }

/* 编辑态 */
.user-info--editing { flex: 1; justify-content: center; gap: 12rpx; display: flex; flex-direction: column; }
.edit-field-label { font-size: 22rpx; color: var(--text-phantom); font-family: var(--font-mono); letter-spacing: 2rpx; }
.edit-nick-input {
  background-color: var(--bg-sunken);
  border: 1rpx solid var(--border);
  border-radius: 6rpx;
  padding: 16rpx 20rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
}
.edit-nick-placeholder { color: var(--text-phantom); font-size: 28rpx; }
.edit-actions { display: flex; gap: 16rpx; margin-top: 4rpx; }
.edit-btn {
  flex: 1; text-align: center;
  padding: 14rpx 0;
  border-radius: 6rpx;
  font-size: 26rpx;
  font-family: var(--font-mono);
}
.edit-btn--cancel { background-color: var(--bg-elevated); color: var(--text-muted); border: 1rpx solid var(--border); }
.edit-btn--save   { background-color: var(--accent-red); color: var(--text-primary); }
.edit-btn--saving { opacity: 0.6; }

.user-tag {
  background-color: var(--bg-green-dim);
  border: 1rpx solid var(--border-green);
  color: var(--accent-green);
  font-size: 22rpx; font-family: var(--font-mono);
  padding: 4rpx 14rpx; border-radius: 4rpx;
}

.my-stats    { display: flex; align-items: center; padding: 32rpx; border-bottom: 1rpx solid var(--border); }
.my-stat-item{ flex: 1; display: flex; flex-direction: column; align-items: center; }
.my-stat-num { font-size: 46rpx; font-weight: 700; color: var(--text-primary); font-family: var(--font-mono); }
.my-stat-label{ font-size: 22rpx; color: var(--text-ghost); margin-top: 8rpx; }
.stat-divider { width: 1rpx; height: 60rpx; background-color: var(--border); }

.menu-section { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }

.menu-group {
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 8rpx; overflow: hidden;
}

.menu-item {
  display: flex; align-items: center;
  padding: 28rpx; border-bottom: 1rpx solid var(--border-faint);
  gap: 20rpx;
}

.menu-item:last-child { border-bottom: none; }

.menu-icon  { font-size: 30rpx; color: var(--accent-green); flex-shrink: 0; }
.menu-label { flex: 1; font-size: 30rpx; color: var(--text-secondary); }
.menu-arrow { font-size: 38rpx; color: var(--text-void); }

.system-info { padding: 24rpx 32rpx 40rpx; display: flex; flex-direction: column; gap: 8rpx; align-items: center; }

.sys-info-text {
  font-size: 20rpx; color: var(--text-void);
  font-family: var(--font-mono); letter-spacing: 1rpx;
  text-align: center; display: block;
}

/* ── 未登录横幅 ── */
.login-prompt-banner {
  padding: 64rpx 32rpx 48rpx;
  border-bottom: 1rpx solid var(--border);
  background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-base) 100%);
}

.login-prompt-inner { display: flex; flex-direction: column; align-items: center; gap: 16rpx; }

.login-prompt-logo { font-size: 82rpx; color: var(--border); }
.login-prompt-title { font-size: 38rpx; font-weight: 600; color: var(--text-primary); }
.login-prompt-sub { font-size: 26rpx; color: var(--text-ghost); text-align: center; line-height: 1.6; }

.login-prompt-btn {
  margin-top: 16rpx;
  padding: 24rpx 60rpx;
  background-color: var(--accent-red);
  border-radius: 6rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  font-family: var(--font-mono);
  letter-spacing: 2rpx;
}

/* ── 设置区 ── */
.settings-section { padding: 24rpx; }

.settings-group {
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
}

.settings-picker-val {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.settings-val-text { font-size: 28rpx; color: var(--text-secondary); }

/* ── 危险操作菜单项 ── */
.menu-item--danger { }
.menu-icon--danger { color: var(--accent-red); }
.menu-label--danger { color: var(--accent-red); }
