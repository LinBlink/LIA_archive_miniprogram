<!-- pages/profile/profile.wxml -->
<view class="page-container">

  <!-- 用户信息头部 -->
  <view class="profile-header">
    <view class="user-avatar-wrap">
      <image class="user-avatar" src="{{userInfo.avatarUrl || ''}}" mode="aspectFill" wx:if="{{userInfo.avatarUrl}}"/>
      <view class="user-avatar-placeholder" wx:else>
        <text class="avatar-icon">⬡</text>
      </view>
      <view class="user-level-badge">Lv.{{userLevel}}</view>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '匿名调查员'}}</text>
      <text class="user-id-str">UID: {{uidStr}}</text>
      <view class="user-tag-row">
        <view class="user-tag">档案研究者</view>
      </view>
    </view>
  </view>

  <!-- 统计数据行 -->
  <view class="my-stats">
    <view class="my-stat-item">
      <text class="my-stat-num">{{myArchiveCount}}</text>
      <text class="my-stat-label">我的档案</text>
    </view>
    <view class="stat-divider"></view>
    <view class="my-stat-item">
      <text class="my-stat-num">{{myCollectCount}}</text>
      <text class="my-stat-label">收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="my-stat-item">
      <text class="my-stat-num">{{totalViews}}</text>
      <text class="my-stat-label">获浏览</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="onMyArchives">
        <text class="menu-icon">◈</text>
        <text class="menu-label">我录入的档案</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onMyCollects">
        <text class="menu-icon">◇</text>
        <text class="menu-label">我的收藏</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onMyDraft">
        <text class="menu-icon">⊡</text>
        <text class="menu-label">草稿箱</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="onAbout">
        <text class="menu-icon">⬡</text>
        <text class="menu-label">关于閾界档案馆</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onFeedback">
        <text class="menu-icon">⊞</text>
        <text class="menu-label">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 系统信息 -->
  <view class="system-info">
    <text class="sys-info-text">LIMINALITY ARCHIVE SYSTEM</text>
    <text class="sys-info-text">本档案馆仅收录未经官方完整解释的异常事件</text>
    <text class="sys-info-text">所有档案均来自用户投稿，仅供研究参考</text>
  </view>

</view>
